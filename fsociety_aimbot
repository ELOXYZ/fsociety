    label.TextSize = 16
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame

    local button = Instance.new("TextButton")
    button.Size = UDim2.new(0, 55, 0, 24)
    button.Position = UDim2.new(1, -55, 0.5, -12)
    button.BackgroundColor3 = Config[configKey] and Config.ThemeColor or Color3.fromRGB(35, 35, 35)
    button.Text = Config[configKey] and "ON" or "OFF"
    button.TextColor3 = Config[configKey] and Color3.fromRGB(0,0,0) or Color3.fromRGB(255,255,255)
    button.Font = Enum.Font.Code
    button.TextSize = 12
    button.Parent = frame

