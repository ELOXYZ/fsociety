    label.Parent = frame

    local button = Instance.new("TextButton")
    button.Size = UDim2.new(0, 55, 0, 24)
    button.Position = UDim2.new(1, -55, 0.5, -12)
    button.BackgroundColor3 = Config[configKey] and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(35, 35, 35)
    button.Text = Config[configKey] and "ON" or "OFF"
    button.TextColor3 = Color3.fromRGB(0, 0, 0)
    button.Font = Enum.Font.Code
    button.TextSize = 12
    button.Parent = frame

    Instance.new("UICorner", button).CornerRadius = UDim.new(0, 4)

    button.MouseButton1Click:Connect(function()
        Config[configKey] = not Config[configKey]
        button.Text = Config[configKey] and "ON" or "OFF"
        TweenService:Create(button, TweenInfo.new(0.15), {
            BackgroundColor3 = Config[configKey] and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(35, 35, 35)
        }):Play()
    end)
end

local function createSlider(name, min, max, configKey, decimals)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 50)
    frame.BackgroundTransparency = 1
    frame.Parent = Content

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 20)
    label.BackgroundTransparency = 1
    label.Text = " " .. name .. ": " .. string.format(decimals and "%.2f" or "%d", Config[configKey])
    label.TextColor3 = Color3.fromRGB(240, 240, 240)
    label.Font = Enum.Font.SourceSansBold
    label.TextSize = 16
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, -10, 0, 6)
    bg.Position = UDim2.new(0, 5, 0, 28)
    bg.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    bg.Parent = frame

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((Config[configKey] - min) / (max - min), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(255, 255, 255)   -- White
    fill.Parent = bg

    local knob = Instance.new("ImageButton")
    knob.Size = UDim2.new(0, 12, 0, 12)
    knob.Position = UDim2.new((Config[configKey] - min) / (max - min), -6, 0.5, -6)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Parent = bg
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local dragging = false

    local function update(input)
        local pos = input.Position.X - bg.AbsolutePosition.X
        local percent = math.clamp(pos / bg.AbsoluteSize.X, 0, 1)
        local value = min + percent * (max - min)
        if not decimals then value = math.round(value) end

        fill.Size = UDim2.new(percent, 0, 1, 0)
        knob.Position = UDim2.new(percent, -6, 0.5, -6)
        Config[configKey] = value
        label.Text = " " .. name .. ": " .. string.format(decimals and "%.2f" or "%d", value)
    end

    knob.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
    end)

    table.insert(connections, UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end))

    table.insert(connections, UserInputService.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            update(inp)
        end
    end))
end

