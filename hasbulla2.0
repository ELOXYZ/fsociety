getgenv().GamingChairSilentAimCleanup = function()
    for _, conn in ipairs(connections) do if conn.Connected then conn:Disconnect() end end
    if flightBodyVelocity then flightBodyVelocity:Destroy() end
    if getgenv().ChairFOVCircle then
        getgenv().ChairFOVCircle:Remove()
        getgenv().ChairFOVCircle = nil
    end
    local ui = ((gethui and gethui()) or game:GetService("CoreGui")):FindFirstChild("hasbulla_menu")
    if ui then ui:Destroy() end
end

