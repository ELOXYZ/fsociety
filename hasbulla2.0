table.insert(connections, UserInputService.InputBegan:Connect(function(input, gp)
	if gp then return end

	if input.KeyCode == Enum.KeyCode.Insert then
		Main.Visible = not Main.Visible
	elseif input.KeyCode == Config.Keybind then
		Config.Enabled = not Config.Enabled
		print("Aimbot " .. (Config.Enabled and "Enabled" or "Disabled"))
	elseif input.KeyCode == Config.FlightKey then
		Config.FlightEnabled = not Config.FlightEnabled
	end
end))

local function isWallBetween(origin, targetPos)
    if not Config.WallCheck then return false end
    local direction = (targetPos - origin)
    local distance = direction.Magnitude
    if distance < 8 then return false end
    direction = direction.Unit

    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.IgnoreWater = true

    local result = Workspace:Raycast(origin + direction * 4, direction * (distance - 8), raycastParams)
    return result ~= nil
end

local function isAlive(p)
	return p and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0
end

local function getClosestPlayer()
	if not Config.Enabled then return nil end
	local mouse = UserInputService:GetMouseLocation()
	local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	local closest, dist = nil, math.huge

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr == LocalPlayer or not isAlive(plr) then continue end
		if Config.TeamCheck and plr.Team == LocalPlayer.Team then continue end
		if Config.FriendCheck and LocalPlayer:IsFriendsWith(plr.UserId) then continue end

		local part = plr.Character:FindFirstChild(Config.TargetPart)
		if not part then continue end

		if myRoot and (myRoot.Position - part.Position).Magnitude > 200 then continue end

		if myRoot and isWallBetween(myRoot.Position, part.Position) then continue end

		local screen, onscreen = Camera:WorldToViewportPoint(part.Position)
		if onscreen then
			local d = (Vector2.new(screen.X, screen.Y) - mouse).Magnitude
			if d < Config.FieldOfView and d < dist then
				dist = d
				closest = plr
			end
		end
	end
	return closest
end

table.insert(connections, RunService.RenderStepped:Connect(function()
	if Config.Enabled then
		local target = getClosestPlayer()
		if target and target.Character then
			local part = target.Character:FindFirstChild(Config.TargetPart)
			if part then
				local targetCF = CFrame.lookAt(Camera.CFrame.Position, part.Position)
				Camera.CFrame = Camera.CFrame:Lerp(targetCF, 1 - Config.Smoothness)
			end
		end
	end

	local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	if Config.FlightEnabled and root then
		if not flightBodyVelocity then
			flightBodyVelocity = Instance.new("BodyVelocity")
			flightBodyVelocity.MaxForce = Vector3.new(1e5,1e5,1e5)
			flightBodyVelocity.Parent = root
		end
		local dir = Vector3.new()
		if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += Camera.CFrame.LookVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= Camera.CFrame.LookVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= Camera.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += Camera.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.new(0,1,0) end
		if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir -= Vector3.new(0,1,0) end

		flightBodyVelocity.Velocity = dir.Magnitude > 0 and dir.Unit * Config.FlightSpeed or Vector3.new()
	else
		if flightBodyVelocity then flightBodyVelocity:Destroy() flightBodyVelocity = nil end
	end
end))

