local oldUI = (gethui and gethui() or game:GetService("CoreGui")):FindFirstChild("hasbulla_menu")
if oldUI then oldUI:Destroy() end

if getgenv().ChairFOVCircle then
    getgenv().ChairFOVCircle:Remove()
    getgenv().ChairFOVCircle = nil
end

local clearTargets = {game:GetService("CoreGui"), game:GetService("Players").LocalPlayer:FindFirstChild("PlayerGui")}

for _, parent in ipairs(clearTargets) do
    if parent then
        for _, child in ipairs(parent:GetChildren()) do
            if child.Name:match("silentaim") or child.Name:match("gaming_chair") or 
               (child:IsA("ScreenGui") and child:FindFirstChild("MainFrame")) then
                child:Destroy()
            end
        end
    end
end

if getgenv().GamingChairSilentAimCleanup then pcall(getgenv().GamingChairSilentAimCleanup) end

